# Docker Compose defaults are local-only. Copy this file to .env before editing.
MERIDIAN_HTTP_BIND=127.0.0.1
MERIDIAN_HTTP_PORT=18080
# Compatibility ports for older reverse-proxy configs that split API/UI.
MERIDIAN_BACKEND_HTTP_PORT=18091
MERIDIAN_FRONTEND_LEGACY_HTTP_PORT=18092
# Optional public URL used by private deployment smoke checks.
MERIDIAN_DEPLOY_VERIFY_URL=

POSTGRES_DB=meridian
POSTGRES_USER=meridian
POSTGRES_PASSWORD=change-me

# Leave MERIDIAN_DATABASE_URL unset for the bundled Compose PostgreSQL service.
# Set it only when using an external database. URL-encode special characters.
# Compose intentionally ignores host-level DATABASE_URL so old shell or CI
# values do not override the bundled database connection.
# MERIDIAN_DATABASE_URL=postgres://meridian:change-me@postgres:5432/meridian?sslmode=disable

# Leave empty to use the first-run browser setup flow.
WORKBENCH_AUTH_USERS=
WORKBENCH_AUTH_SESSION_SECRET=
WORKBENCH_RUNNER_TOKEN=

# Set true when serving Meridian over HTTPS.
WORKBENCH_AUTH_COOKIE_SECURE=false
CODEX_BYPASS_APPROVALS_AND_SANDBOX=true
